# Copy this file to .env and fill in your values. The .env file is gitignored.
# Hugging Face access token with read scope: https://huggingface.co/settings/tokens
HF_TOKEN=

# Max input tokens before truncation (default 16384, clamped to 131072;
# non-integer/zero/negative falls back to the default). Higher = more context
# but more memory (~160 KB KV cache/token) and slower prefill; raise only on a
# higher-RAM Mac. Leave unset to use the default.
# MAX_INPUT_TOKENS=16384
